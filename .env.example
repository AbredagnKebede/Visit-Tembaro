# Database (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/visit_tembaro"

# NextAuth (required for admin login)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-for-production"

# Optional: uploads directory (default: public/uploads)
UPLOAD_DIR="public/uploads"

# Optional: seed admin (when running npm run db:seed)
# SEED_ADMIN_EMAIL=admin@visit-tembaro.local
# SEED_ADMIN_PASSWORD=Admin123!
